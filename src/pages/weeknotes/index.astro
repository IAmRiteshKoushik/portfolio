---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { WEEKNOTES } from "@consts";

const posts = (await getCollection("weeknotes"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatWeeknoteDate = (date: Date) => {
  const base = date.toLocaleDateString("en-GB", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
  const [day, month, year] = base.split(" ");
  return `${day} ${month}, ${year}`;
};
---

<PageLayout title={WEEKNOTES.TITLE} description={WEEKNOTES.DESCRIPTION}>
  <Container>
    <section class="animate weeknote-index">
      <h1 class="weeknote-index-title">Weeknotes</h1>
      <p class="weeknote-index-description">{WEEKNOTES.DESCRIPTION}</p>

      <ul class="weeknote-index-list"s>
        {posts.map((post) => (
          <li class="weeknote-index-row">
            <time class="weeknote-index-date" datetime={post.data.date.toISOString()}>
              {formatWeeknoteDate(post.data.date)}
            </time>
            <div>
            <a class="weeknote-index-link" href={`/weeknotes/${post.slug}/`}>
              {post.data.title}
            </a>
            <p class="weeknote-index-row-subtext">
              {post.data.description}
            </p>
            </div>
          </li>
        ))}
      </ul>
    </section>
  </Container>
</PageLayout>

<style>
  .weeknote-index {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .weeknote-index-title {
    margin: 0;
    font-family: "Instrument Serif", serif;
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.05;
  }

  .weeknote-index-description {
    margin: 0;
    color: var(--muted);
    max-width: 68ch;
    line-height: 1.6;
  }

  .weeknote-index-list {
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
  }

  .weeknote-index-row {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr);
    align-items: baseline;
    column-gap: 1.2rem;
    padding: 0.95rem 0.65rem;
    transition: background-color 180ms ease;
  }

  .weeknote-index-row + .weeknote-index-row {
    border-top: 1px solid var(--line);
  }

  .weeknote-index-row:hover {
    background: color-mix(in srgb, var(--text) 6%, transparent);
  }

  .weeknote-index-row-subtext {
    color: var(--muted);
  }

  .weeknote-index-date {
    font-family: "JetBrains Mono", monospace;
    color: var(--muted);
    font-size: 0.82rem;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .weeknote-index-link {
    color: var(--text);
    text-decoration: none;
    font-size: clamp(0.9rem, 1.02vw, 1.04rem);
    line-height: 1.35;
    font-weight: 560;
  }

  .weeknote-index-link:hover {
    color: var(--accent-text);
  }

  @media (max-width: 640px) {
    .weeknote-index-row {
      grid-template-columns: 1fr;
      row-gap: 0.4rem;
    }
  }
</style>
